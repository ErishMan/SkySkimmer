# ============================================================
# SkySkimmer — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# --- Tequila by Kiwi API ---
# Obtain from: https://tequila.kiwi.com/portal
TEQUILA_API_KEY=

# --- Notification Webhooks ---
# Discord: Server Settings > Integrations > Webhooks
DISCORD_WEBHOOK_URL=
# Optional: separate channel for system errors/alerts
DISCORD_ERROR_WEBHOOK_URL=

# --- State Store: Supabase ---
# Leave blank to fall back to local JSON file state store
SUPABASE_URL=
SUPABASE_KEY=

# --- Scheduler ---
# How often to poll, in minutes (default: 30)
POLL_INTERVAL_MINUTES=30

# --- Application ---
# Environment: development | production
APP_ENV=development
# Minimum log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
